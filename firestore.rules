rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 任何人都可以读取所有数据
    match /{document=**} {
      allow read: if true;
    }

    // 管理配置集合 - 用于存储管理员密码
    match /admin/{docId} {
      allow read, write: if true;
    }

    // 作品集合 - 允许创建和更新
    match /creations/{docId} {
      allow create: if request.resource.data.keys().hasAll(['title', 'description', 'tag']);
      allow update, delete: if true;
    }

    // 设置集合 - 联系信息
    match /settings/contact {
      allow read, write: if true;
    }
  }
}